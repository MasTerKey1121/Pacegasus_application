# =========================================================
# Pacegasus Backend - Environment Settings
# Copy this file to ".env" and fill in real values.
# =========================================================

# --- Server ---
PORT=4000
NODE_ENV=development
# Frontend origin allowed to call this API (React Native dev / web dev server)
CLIENT_URL=http://localhost:8081

# --- Database (PostgreSQL, e.g. local Postgres or Supabase) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pacegasus
DB_SSL=false

# --- JWT ---
JWT_ACCESS_SECRET=replace_with_a_long_random_string
JWT_REFRESH_SECRET=replace_with_a_different_long_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# --- OTP (Email login/register) ---
OTP_LENGTH=6
OTP_EXPIRES_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60

# --- Email / SMTP (used to send the 6-digit OTP) ---
# Example values work with a Gmail App Password. Any SMTP provider works
# (Mailtrap for local testing, SendGrid, Amazon SES SMTP, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM_NAME=Pacegasus
SMTP_FROM_EMAIL=your_email@gmail.com

# --- Google Sign-In ---
# OAuth 2.0 Client ID (Web application type) from Google Cloud Console.
# The frontend gets a Google ID token and sends it to POST /api/auth/google
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
