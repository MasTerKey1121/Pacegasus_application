    },
    {
      "name": "1. Authentication",
      "item": [
        {
          "name": "1.1 Request OTP (Register)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/otp/request",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "otp",
                "request"
              ]
            },
            "description": "**POST /api/auth/otp/request**\n\nขอรหัส OTP 6 หลักส่งไปที่อีเมล เพื่อใช้สมัครสมาชิกใหม่ (`purpose: \"register\"`)\nระบบจะสร้าง user แถวใหม่ (ยังไม่ verified) ถ้ายังไม่เคยมีอีเมลนี้ในระบบ\n\n### Request Body\n| Field | Type | Required | คำอธิบาย |\n|---|---|---|---|\n| email | string | ✅ | อีเมลที่จะสมัคร |\n| purpose | string | ✅ | `\"register\"` หรือ `\"login\"` |\n\n### Response 200 OK\n```json\n{\n  \"success\": true,\n  \"message\": \"ส่งรหัส OTP ไปยังอีเมลของคุณแล้ว\",\n  \"data\": { \"email\": \"tester@example.com\", \"expiresInMinutes\": 5 }\n}\n```\n\n### Error responses\n| Status | สาเหตุ |\n|---|---|\n| 400 | รูปแบบอีเมล/purpose ไม่ถูกต้อง |\n| 409 | purpose=register แต่มีอีเมลนี้ verified อยู่แล้ว |\n| 429 | ขอ OTP ถี่เกินไป (ต้องรอ cooldown ~60 วิ) |",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"purpose\": \"register\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has success field', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('success');",
                  "});",
                  "",
                  "pm.test('Has expiresInMinutes', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.data).to.have.property('expiresInMinutes');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "1.2 Verify OTP (Register)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/otp/verify",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "otp",
                "verify"
              ]
            },
            "description": "**POST /api/auth/otp/verify**\n\nยืนยันรหัส OTP ที่ได้รับทางอีเมล เมื่อสำเร็จจะสร้าง session ให้ทันที (ทั้ง register และ login ใช้ endpoint เดียวกัน)\n\n⚠️ **ก่อนกดส่ง**: แก้ค่า `otp` ในตัวอย่าง body ให้เป็นรหัส 6 หลักที่ได้รับจริงทางอีเมล (หรือดึงจากตาราง `otp_codes` ตอน dev)\n\n### Request Body\n| Field | Type | Required | คำอธิบาย |\n|---|---|---|---|\n| email | string | ✅ | อีเมลเดียวกับที่ขอ OTP |\n| otp | string(6) | ✅ | รหัส OTP ที่ได้รับ |\n| displayName | string | ❌ | ชื่อที่แสดง (ใส่ตอนสมัครครั้งแรก) |\n\n### Response 200 OK\n```json\n{\n  \"success\": true,\n  \"message\": \"เข้าสู่ระบบสำเร็จ\",\n  \"data\": {\n    \"user\": {\n      \"id\": \"uuid\",\n      \"email\": \"tester@example.com\",\n      \"emailVerified\": true,\n      \"displayName\": \"Tester\",\n      \"avatarUrl\": null,\n      \"role\": \"user\",\n      \"onboardingCompleted\": false,\n      \"onboardingStep\": 0,\n      \"createdAt\": \"2026-07-19T15:51:16.483Z\"\n    },\n    \"accessToken\": \"<JWT, อายุ 15 นาที>\",\n    \"refreshToken\": \"<opaque token, อายุ 30 วัน>\"\n  }\n}\n```\n\n### Error responses\n| Status | สาเหตุ |\n|---|---|\n| 400 | ไม่พบคำขอ OTP / OTP หมดอายุ / OTP ไม่ถูกต้อง |\n| 429 | กรอกผิดเกินจำนวนครั้งที่กำหนด (default 5 ครั้ง) |\n\n> Test script ของ request นี้จะ auto-save `accessToken`, `refreshToken`, `userId` เป็น collection variable ให้ request ถัดไปใช้ต่อทันที",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"otp\": \"{{testOtp}}\",\n  \"displayName\": \"Tester\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response contains tokens and user', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.success).to.eql(true);",
                  "    pm.expect(json.data).to.have.property('accessToken');",
                  "    pm.expect(json.data).to.have.property('refreshToken');",
                  "    pm.expect(json.data.user).to.have.property('id');",
                  "});",
                  "",
                  "// Auto-save tokens for the rest of the collection",
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "    pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
                  "    pm.collectionVariables.set('userId', json.data.user.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "1.3 Request OTP (Login)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
