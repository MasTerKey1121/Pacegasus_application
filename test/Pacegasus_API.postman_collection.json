    {
      "name": "2. Onboarding",
      "item": [
        {
          "name": "2.0 Get Onboarding Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/onboarding/status",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "onboarding",
                "status"
              ]
            },
            "description": "**GET /api/onboarding/status**\n\nเช็คว่าผู้ใช้ทำ onboarding ไปถึงขั้นตอนไหนแล้ว — เรียกได้ทุกเมื่อหลัง login เพื่อตัดสินใจว่าจะพาไปหน้าไหนต่อ\n\nต้องแนบ `Authorization: Bearer {{accessToken}}`\n\n### Response 200 OK\n```json\n{\n  \"success\": true,\n  \"data\": { \"currentStep\": 0, \"completed\": false }\n}\n```\n`currentStep`: 0 = ยังไม่เริ่ม, 1-4 = ทำถึงขั้นตอนล่าสุดที่เสร็จแล้ว",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has success field', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('success');",
                  "});",
                  "",
                  "pm.test('Has currentStep and completed', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.data).to.have.property('currentStep');",
                  "    pm.expect(json.data).to.have.property('completed');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "2.1 Step 1 - Basic Info",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/onboarding/step1",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "onboarding",
                "step1"
              ]
            },
            "description": "**PUT /api/onboarding/step1**\n\nบันทึกข้อมูลพื้นฐาน (Onboarding หน้าที่ 1) — เรียกซ้ำได้ (upsert)\n\nต้องแนบ `Authorization: Bearer {{accessToken}}`\n\n### Request Body\n| Field | Type | Required | ค่าที่รับได้ |\n|---|---|---|---|\n| dateOfBirth | string (ISO date) | ✅ | เช่น `1998-05-10` |\n| gender | string | ✅ | `male` \\| `female` \\| `other` \\| `prefer_not_to_say` |\n| heightCm | number | ✅ | 80–250 |\n| weightKg | number | ✅ | 20–300 |\n| runningExperienceLevel | string | ✅ | `beginner` \\| `intermediate` \\| `advanced` \\| `elite` |\n| weeklyDistanceKm | number | ✅ | 0–500 |\n| runningDaysPerWeek | number | ✅ | 0–7 |\n| timezone | string | ❌ | default `Asia/Bangkok` |\n\n### Response 200 OK\n```json\n{ \"success\": true, \"message\": \"บันทึกข้อมูลพื้นฐานสำเร็จ\", \"data\": { \"step\": 1 } }\n```\n### Error\n| Status | สาเหตุ |\n|---|---|\n| 400 | field ไม่ครบ / ค่านอกช่วงที่กำหนด |\n| 401 | ไม่ได้ login |",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"dateOfBirth\": \"1998-05-10\",\n  \"gender\": \"male\",\n  \"heightCm\": 175,\n  \"weightKg\": 68,\n  \"runningExperienceLevel\": \"beginner\",\n  \"weeklyDistanceKm\": 15,\n  \"runningDaysPerWeek\": 3,\n  \"timezone\": \"Asia/Bangkok\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has success field', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('success');",
                  "});",
                  "",
                  "pm.test('Step number is 1', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.data.step).to.eql(1);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "2.2 Step 2 - Injury History",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/onboarding/step2",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "onboarding",
                "step2"
              ]
            },
            "description": "**PUT /api/onboarding/step2**\n\nบันทึกประวัติการบาดเจ็บ (Onboarding หน้าที่ 2) — ส่งซ้ำจะ **แทนที่รายการ injuries เดิมทั้งหมด**\n\nต้องแนบ `Authorization: Bearer {{accessToken}}`\n\n### Request Body\n| Field | Type | Required | คำอธิบาย |\n|---|---|---|---|\n| hasInjuryHistory | boolean | ✅ | มีประวัติบาดเจ็บหรือไม่ |\n| injuries | array | ❌ | รายการบาดเจ็บ (ใช้เมื่อ hasInjuryHistory=true) |\n\nแต่ละ item ใน `injuries`:\n| Field | Type | Required |\n|---|---|---|\n| bodyPart | string | ✅ |\n| injuryType | string | ❌ |\n| severity | number (1-10) | ❌ |\n| isCurrent | boolean | ❌ (default false) |\n| occurredAt | string (ISO date) | ❌ |\n| notes | string | ❌ |\n\n### Response 200 OK\n```json\n{ \"success\": true, \"message\": \"บันทึกประวัติการบาดเจ็บสำเร็จ\", \"data\": { \"step\": 2 } }\n```",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"hasInjuryHistory\": true,\n  \"injuries\": [\n    {\n      \"bodyPart\": \"knee\",\n      \"injuryType\": \"runner's knee\",\n      \"severity\": 3,\n      \"isCurrent\": false,\n      \"occurredAt\": \"2025-03-01\",\n      \"notes\": \"หายแล้ว แต่ยังระวังตอนวิ่งลงเนิน\"\n    }\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has success field', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('success');",
                  "});",
                  "",
                  "pm.test('Step number is 2', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.data.step).to.eql(2);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "2.3 Step 3 - Goals",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/onboarding/step3",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "onboarding",
                "step3"
              ]
            },
            "description": "**PUT /api/onboarding/step3**\n\nบันทึกเป้าหมายการวิ่ง (Onboarding หน้าที่ 3) — ส่งซ้ำจะ **แทนที่รายการ goals เดิมทั้งหมด**\n\nต้องแนบ `Authorization: Bearer {{accessToken}}`\n\n### Request Body\n| Field | Type | Required |\n|---|---|---|\n| goals | array (อย่างน้อย 1 รายการ) | ✅ |\n\nแต่ละ item ใน `goals`:\n| Field | Type | Required | ค่าที่รับได้ |\n|---|---|---|---|\n| goalType | string | ✅ | `lose_weight` \\| `run_5k` \\| `run_10k` \\| `half_marathon` \\| `marathon` \\| `general_fitness` \\| `improve_pace` \\| `stay_consistent` |\n| targetDistanceKm | number | ❌ | |\n| targetDate | string (ISO date) | ❌ | |\n| targetPaceSecPerKm | number | ❌ | วินาที/กม. (120–1200) |\n| isPrimary | boolean | ❌ | default false |\n\n### Response 200 OK\n```json\n{ \"success\": true, \"message\": \"บันทึกเป้าหมายสำเร็จ\", \"data\": { \"step\": 3 } }\n```",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"goals\": [\n    {\n      \"goalType\": \"run_10k\",\n      \"targetDistanceKm\": 10,\n      \"targetDate\": \"2026-12-01\",\n      \"targetPaceSecPerKm\": 330,\n      \"isPrimary\": true\n    },\n    {\n      \"goalType\": \"stay_consistent\",\n      \"isPrimary\": false\n    }\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has success field', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('success');",
                  "});",
                  "",
                  "pm.test('Step number is 3', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.data.step).to.eql(3);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "2.4 Step 4 - Running History (Final)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/onboarding/step4",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "onboarding",
                "step4"
              ]
            },
            "description": "**PUT /api/onboarding/step4**\n\nบันทึกประวัติการวิ่ง (Onboarding หน้าที่ 4, ขั้นตอนสุดท้าย) — เมื่อสำเร็จจะตั้ง `onboarding_completed = true` ให้ผู้ใช้ทันที\n\nต้องแนบ `Authorization: Bearer {{accessToken}}`\n\n### Request Body\n| Field | Type | Required | ค่าที่รับได้ |\n|---|---|---|---|\n| hasRunBefore | boolean | ✅ | |\n| yearsRunning | number | ❌ | 0–80 |\n| best5kSeconds | number | ❌ | best time หน่วยวินาที |\n| best10kSeconds | number | ❌ | |\n| bestHalfMarathonSeconds | number | ❌ | |\n| bestMarathonSeconds | number | ❌ | |\n| preferredEnvironment | string | ❌ | `park` \\| `road` \\| `city` \\| `treadmill` \\| `trail` |\n| typicalTrainingTime | string | ❌ | `early_morning` \\| `morning` \\| `afternoon` \\| `evening` \\| `night` |\n| connectedStrava | boolean | ❌ | default false |\n\n### Response 200 OK\n```json\n{\n  \"success\": true,\n  \"message\": \"บันทึกประวัติการวิ่งสำเร็จ — Onboarding เสร็จสมบูรณ์\",\n  \"data\": { \"step\": 4, \"onboardingCompleted\": true }\n}\n```",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"hasRunBefore\": true,\n  \"yearsRunning\": 1.5,\n  \"best5kSeconds\": 1500,\n  \"best10kSeconds\": 3200,\n  \"bestHalfMarathonSeconds\": null,\n  \"bestMarathonSeconds\": null,\n  \"preferredEnvironment\": \"park\",\n  \"typicalTrainingTime\": \"morning\",\n  \"connectedStrava\": false\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Onboarding marked completed', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.data.step).to.eql(4);",
                  "    pm.expect(json.data.onboardingCompleted).to.eql(true);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "3. Users",
      "item": [
        {
          "name": "3.1 Get Full Profile",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/users/me/full",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "me",
                "full"
              ]
            },
            "description": "**GET /api/users/me/full**\n\nรวมข้อมูลผู้ใช้ทั้งหมดในครั้งเดียว (user + basicInfo + injury + goals + runningHistory) — เหมาะใช้ตอนโหลดหน้า Home/Profile หลัง onboarding เสร็จ\n\nต้องแนบ `Authorization: Bearer {{accessToken}}`\n\n### Response 200 OK\n```json\n{\n  \"success\": true,\n  \"data\": {\n    \"user\": { \"id\": \"...\", \"email\": \"...\", \"displayName\": \"...\", \"onboardingCompleted\": true, \"onboardingStep\": 4, ... },\n    \"basicInfo\": { \"date_of_birth\": \"...\", \"gender\": \"male\", \"height_cm\": \"175.00\", ... } ,\n    \"injury\": { \"has_injury_history\": true, \"injuries\": [ { \"body_part\": \"knee\", ... } ] },\n    \"goals\": [ { \"goal_type\": \"run_10k\", \"is_primary\": true, ... } ],\n    \"runningHistory\": { \"has_run_before\": true, \"preferred_environment\": \"park\", ... }\n  }\n}\n```\n\nหมายเหตุ: `basicInfo`/`injury`/`runningHistory` จะเป็น `null`/ค่า default ถ้ายังไม่เคยบันทึก onboarding ขั้นตอนนั้น",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has success field', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('success');",
                  "});",
                  "",
                  "pm.test('Has all profile sections', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.data).to.have.property('user');",
                  "    pm.expect(json.data).to.have.property('basicInfo');",
                  "    pm.expect(json.data).to.have.property('injury');",
                  "    pm.expect(json.data).to.have.property('goals');",
                  "    pm.expect(json.data).to.have.property('runningHistory');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}